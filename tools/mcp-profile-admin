#!/usr/bin/env python3
"""
mcp-profile-admin -- Gateway user profile manager for suitecrm-mcp v3.x

Manage API keys and per-user CRM credentials stored in user-profiles.json.
The gateway writes this file automatically on OAuth login. Use this tool
for manual intervention: revoking keys, checking expiry, or adding a user
who cannot authenticate via the normal OAuth flow.

Usage:
  mcp-profile-admin list                          # list all users + key status
  mcp-profile-admin show <sub>                    # show full profile for a user
  mcp-profile-admin revoke <sub>                  # revoke API key (user must re-auth)
  mcp-profile-admin revoke-all                    # revoke all API keys
  mcp-profile-admin add-cred <sub> <code> <user> <pass>   # add/update CRM cred for an entity
  mcp-profile-admin rm-cred <sub> <code>          # remove CRM cred for an entity
  mcp-profile-admin clean                         # remove profiles with no API key
  mcp-profile-admin export <sub>                  # export a profile as JSON (stdout)

Options:
  --profiles PATH   Path to user-profiles.json (default: /etc/suitecrm-mcp/user-profiles.json)
  --yes             Skip confirmation prompts

The sub argument is the OAuth subject identifier (shown in mcp-profile-admin list).
"""

import argparse
import json
import os
import sys
import time
from copy import deepcopy
from datetime import datetime, timezone

DEFAULT_PROFILES = "/etc/suitecrm-mcp/user-profiles.json"

GREEN  = "\033[0;32m"
YELLOW = "\033[1;33m"
RED    = "\033[0;31m"
CYAN   = "\033[0;36m"
BOLD   = "\033[1m"
NC     = "\033[0m"

def ok(msg):    print(f"{GREEN}[OK]{NC} {msg}")
def info(msg):  print(f"{CYAN}[INFO]{NC} {msg}")
def warn(msg):  print(f"{YELLOW}[WARN]{NC} {msg}")
def fail(msg):  print(f"{RED}[FAIL]{NC} {msg}", file=sys.stderr); sys.exit(1)


def load(path):
    if not os.path.exists(path):
        fail(f"Profiles file not found: {path}\nIs the gateway installed and has anyone authenticated yet?")
    with open(path) as f:
        return json.load(f)


def save(path, data):
    tmp = path + ".tmp"
    with open(tmp, "w") as f:
        json.dump(data, f, indent=2)
    os.replace(tmp, path)
    os.chmod(path, 0o600)


def key_status(profile):
    key = profile.get("api_key", "")
    issued_at = profile.get("api_key_issued_at", "")
    if not key:
        return f"{RED}no key{NC}"
    if not issued_at:
        return f"{GREEN}valid{NC}"
    try:
        issued_ts = datetime.fromisoformat(issued_at.replace('Z', '+00:00')).timestamp()
        ttl_days = int(os.environ.get("API_KEY_TTL_DAYS", "90"))
        expiry_ts = issued_ts + ttl_days * 86400
        now = time.time()
        if expiry_ts < now:
            return f"{YELLOW}expired{NC}"
        return f"{GREEN}valid ({int((expiry_ts - now) / 86400)}d){NC}"
    except Exception:
        return f"{GREEN}valid{NC}"


def fmt_time(ts):
    if not ts:
        return "never"
    return datetime.fromtimestamp(ts, tz=timezone.utc).strftime("%Y-%m-%d %H:%M UTC")


def cmd_list(args, data):
    if not data:
        info("No user profiles found.")
        return
    print(f"\n{'Sub':<36}  {'Email':<32}  {'Linux user':<20}  Status")
    print("-" * 100)
    for sub, p in data.items():
        email = p.get("email", "")
        luser = p.get("linux_user", "")
        status = key_status(p)
        print(f"{sub:<36}  {email:<32}  {luser:<20}  {status}")
    print()


def cmd_show(args, data):
    p = data.get(args.sub) or fail(f"User not found: {args.sub}")
    d = deepcopy(p)
    # redact sensitive fields for display
    if "api_key" in d:
        d["api_key"] = d["api_key"][:12] + "..." + d["api_key"][-4:]
    if "entities" in d:
        for code, cred in d["entities"].items():
            if isinstance(cred, dict) and "pass" in cred:
                cred["pass"] = "***"
    d["_api_key_issued_at_fmt"] = d.get("api_key_issued_at", "never")
    print(json.dumps(d, indent=2))


def cmd_revoke(args, data, path):
    p = data.get(args.sub) or fail(f"User not found: {args.sub}")
    if not args.yes:
        confirm = input(f"Revoke API key for {p.get('email', args.sub)}? [y/N] ").strip().lower()
        if confirm != "y":
            info("Aborted.")
            return
    p.pop("api_key", None)
    p.pop("api_key_issued_at", None)
    save(path, data)
    ok(f"API key revoked for {p.get('email', args.sub)}. User must re-authenticate.")


def cmd_revoke_all(args, data, path):
    if not args.yes:
        confirm = input(f"Revoke ALL API keys ({len(data)} users)? [y/N] ").strip().lower()
        if confirm != "y":
            info("Aborted.")
            return
    count = 0
    for p in data.values():
        if "api_key" in p:
            p.pop("api_key", None)
            p.pop("api_key_issued_at", None)
            count += 1
    save(path, data)
    ok(f"Revoked {count} API key(s). All users must re-authenticate.")


def cmd_add_cred(args, data, path):
    p = data.get(args.sub) or fail(f"User not found: {args.sub}")
    if "entities" not in p:
        p["entities"] = {}
    p["entities"][args.code] = {"user": args.user, "pass": args.password}
    save(path, data)
    ok(f"CRM credential set for {p.get('email', args.sub)} / entity {args.code}")


def cmd_rm_cred(args, data, path):
    p = data.get(args.sub) or fail(f"User not found: {args.sub}")
    creds = p.get("entities", {})
    if args.code not in creds:
        warn(f"No credential found for entity {args.code}")
        return
    del creds[args.code]
    save(path, data)
    ok(f"Credential removed for entity {args.code}")


def cmd_clean(args, data, path):
    before = len(data)
    clean = {sub: p for sub, p in data.items() if p.get("api_key")}
    removed = before - len(clean)
    if removed == 0:
        info("Nothing to clean.")
        return
    if not args.yes:
        confirm = input(f"Remove {removed} profile(s) with no API key? [y/N] ").strip().lower()
        if confirm != "y":
            info("Aborted.")
            return
    save(path, clean)
    ok(f"Removed {removed} inactive profile(s).")


def cmd_export(args, data):
    p = data.get(args.sub) or fail(f"User not found: {args.sub}")
    redacted = {k: v for k, v in p.items() if k not in ("api_key", "refresh_token")}
    if "entities" in redacted:
        redacted["entities"] = {
            code: {ek: ("***" if ek == "pass" else ev) for ek, ev in ent.items()}
            for code, ent in redacted["entities"].items()
        }
    print(json.dumps({args.sub: redacted}, indent=2))


def main():
    parser = argparse.ArgumentParser(description="suitecrm-mcp gateway profile manager",
                                     formatter_class=argparse.RawDescriptionHelpFormatter)
    parser.add_argument("--profiles", default=os.environ.get("PROFILES_FILE", DEFAULT_PROFILES))
    parser.add_argument("--yes", action="store_true")

    sub = parser.add_subparsers(dest="command", required=True)

    sub.add_parser("list")

    p_show = sub.add_parser("show")
    p_show.add_argument("sub")

    p_rev = sub.add_parser("revoke")
    p_rev.add_argument("sub")

    sub.add_parser("revoke-all")

    p_add = sub.add_parser("add-cred")
    p_add.add_argument("sub")
    p_add.add_argument("code")
    p_add.add_argument("user")
    p_add.add_argument("password")

    p_rm = sub.add_parser("rm-cred")
    p_rm.add_argument("sub")
    p_rm.add_argument("code")

    sub.add_parser("clean")

    p_exp = sub.add_parser("export")
    p_exp.add_argument("sub")

    args = parser.parse_args()
    data = load(args.profiles)

    if args.command == "list":          cmd_list(args, data)
    elif args.command == "show":        cmd_show(args, data)
    elif args.command == "revoke":      cmd_revoke(args, data, args.profiles)
    elif args.command == "revoke-all":  cmd_revoke_all(args, data, args.profiles)
    elif args.command == "add-cred":    cmd_add_cred(args, data, args.profiles)
    elif args.command == "rm-cred":     cmd_rm_cred(args, data, args.profiles)
    elif args.command == "clean":       cmd_clean(args, data, args.profiles)
    elif args.command == "export":      cmd_export(args, data)


if __name__ == "__main__":
    main()
