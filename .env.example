# SuiteCRM MCP Gateway — Environment Variables
# Copy this to .env and fill in your values (for manual/development use only)
# The installers write env files to /etc/suitecrm-mcp/ automatically.

# Required: full path to the SuiteCRM v4_1 REST endpoint.
# The path prefix varies by installation — common patterns:
#   https://crm.example.com/service/v4_1/rest.php
#   https://crm.example.com/legacy/service/v4_1/rest.php
#   https://crm.example.com/crm/service/v4_1/rest.php
# See README for how to find yours.
SUITECRM_ENDPOINT=https://your-crm.example.com/service/v4_1/rest.php

# Tool name prefix — all tools will be named <prefix>_search, <prefix>_get, etc.
SUITECRM_PREFIX=suitecrm

# Port the gateway listens on
PORT=3101

# Suppress Node.js deprecation warnings
NODE_NO_WARNINGS=1

# Multi-entity routing: set this to the entity code when running behind nginx.
# The gateway uses this to tell MCP clients where to POST messages.
# Leave blank for single-entity (direct port access, no nginx).
# SUITECRM_CODE=mycrm

# TLS: only set this to "0" if your SuiteCRM uses a self-signed certificate
# and you're on a trusted internal network. Never use in production with public CRMs.
# NODE_TLS_REJECT_UNAUTHORIZED=0
