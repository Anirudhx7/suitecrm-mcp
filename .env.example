# SuiteCRM MCP Gateway - Environment Variables
# Copy this to .env and fill in your values (for manual/development use only)
# The installer writes env files to /etc/suitecrm-mcp/ automatically.

# ── OAuth2 / OIDC ────────────────────────────────────────────────────────────
# OIDC issuer base URL (no trailing slash). The gateway fetches
# /.well-known/openid-configuration from this URL at startup.
# Examples:
#   Auth0:    https://your-tenant.auth0.com
#   Azure AD: https://login.microsoftonline.com/<tenant-id>/v2.0
OAUTH_ISSUER=https://your-tenant.auth0.com

# OAuth2 client ID (from your identity provider app registration)
OAUTH_CLIENT_ID=your-client-id

# OAuth2 client secret (keep this secret - never commit it)
OAUTH_CLIENT_SECRET=your-client-secret

# OAuth2 audience (required for Auth0; usually the API identifier or client ID)
OAUTH_AUDIENCE=https://your-tenant.auth0.com/api/v2/

# The callback URL you registered in your identity provider.
# Must match exactly what you configured in Auth0/Azure AD.
OAUTH_REDIRECT_URI=https://mcp.yourcompany.com/auth/callback

# Publicly reachable base URL of this gateway (used to build redirect URLs)
GATEWAY_EXTERNAL_URL=https://mcp.yourcompany.com

# JWT claim that contains group memberships (default: roles)
# Auth0: configure a custom claim action to include groups/roles
# Azure AD: use "groups" (object IDs) or configure app roles
# OAUTH_GROUPS_CLAIM=roles

# ── Gateway API Keys ──────────────────────────────────────────────────────────
# Secret for HMAC-signing gateway-issued API keys. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY_SECRET=change-me-generate-a-random-64-char-hex-string

# How many days a gateway-issued API key is valid before requiring re-auth (default: 90)
# API_KEY_TTL_DAYS=90

# ── Profile and entity config paths ─────────────────────────────────────────
# Path to the JSON file storing per-user API keys and CRM credentials.
# Written by /auth/callback. Must be readable/writable by the gateway process.
# PROFILES_FILE=/etc/suitecrm-mcp/user-profiles.json

# Path to the entities config generated by install.py (multi-entity mode)
# ENTITIES_CONFIG=/etc/suitecrm-mcp/entities.json

# ── CRM SSH provisioning ─────────────────────────────────────────────────────
# Path to the JSON file mapping entity codes to CRM SSH hosts.
# Format: {"crm1": "crm1.internal", "crm2": "crm2.internal"}
# CRM_HOSTS_FILE=/etc/suitecrm-mcp/crm-hosts.json

# SSH private key path used to connect to CRM VMs for provisioning (default: /root/.ssh/id_ed25519)
# SSH_KEY_PATH=/root/.ssh/id_ed25519

# SSH user on the CRM VMs (default: root)
# SSH_USER=root

# ── Single-entity CRM connection ─────────────────────────────────────────────
# Only used in single-entity mode (no entities.json).
# Full path to the SuiteCRM v4_1 REST endpoint.
# The path prefix varies by installation - common patterns:
#   https://crm.example.com/service/v4_1/rest.php
#   https://crm.example.com/legacy/service/v4_1/rest.php
#   https://crm.example.com/crm/service/v4_1/rest.php
# See README for how to find yours.
SUITECRM_ENDPOINT=https://your-crm.example.com/service/v4_1/rest.php

# Tool name prefix - all tools will be named <prefix>_search, <prefix>_get, etc.
SUITECRM_PREFIX=suitecrm

# Group name required to access this entity (from OAUTH_GROUPS_CLAIM)
# REQUIRED_GROUP=CRM-Access

# ── Network ───────────────────────────────────────────────────────────────────
# Port the gateway listens on
PORT=3101

# Interface to bind on. Default is 0.0.0.0 (required for Docker port mapping).
# For systemd installs behind nginx, the installer sets this to 127.0.0.1.
# BIND_HOST=127.0.0.1

# Suppress Node.js deprecation warnings
NODE_NO_WARNINGS=1

# Multi-entity routing: set this to the entity code when running behind nginx.
# SUITECRM_CODE=mycrm

# TLS: only set this to "0" if your SuiteCRM uses a self-signed certificate
# and you're on a trusted internal network. Never use in production.
# NODE_TLS_REJECT_UNAUTHORIZED=0

# ── Prometheus metrics ────────────────────────────────────────────────────────
# METRICS_PORT=9090
# METRICS_BIND=127.0.0.1

# Set to "1" if the gateway is behind a reverse proxy (nginx) that sets X-Forwarded-For.
# TRUST_PROXY=1
