{
  "title": "SuiteCRM MCP - Fleet Overview",
  "uid": "suitecrm-mcp-fleet",
  "version": 2,
  "schemaVersion": 39,
  "tags": ["suitecrm", "fleet"],
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [
    {
      "name": "entity",
      "label": "Entity",
      "type": "query",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "query": { "query": "label_values(suitecrm_mcp_tool_calls_total, entity)", "refId": "StandardVariableQuery" },
      "refresh": 2,
      "multi": true,
      "includeAll": true,
      "allValue": ".*",
      "sort": 1,
      "hide": 0
    }
  ] },
  "panels": [
    {
      "id": 1,
      "title": "Traffic",
      "type": "row",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "Tool Calls / min by Entity",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 1, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum by (entity) (rate(suitecrm_mcp_tool_calls_total[5m]) * 60)",
          "legendFormat": "{{entity}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 3,
      "title": "Health",
      "type": "row",
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 4,
      "title": "Circuit Breaker State",
      "type": "table",
      "gridPos": { "x": 0, "y": 10, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "suitecrm_mcp_circuit_breaker_state",
          "legendFormat": "{{entity}}",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true },
            "renameByName": { "entity": "Entity", "Value": "State" },
            "indexByName": { "Entity": 0, "State": 1 }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "State" },
            "properties": [
              { "id": "displayName", "value": "State" },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "0": { "text": "Closed", "color": "green" } } },
                  { "type": "value", "options": { "1": { "text": "Half-Open", "color": "yellow" } } },
                  { "type": "value", "options": { "2": { "text": "Open", "color": "red" } } }
                ]
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 1 },
                    { "color": "red", "value": 2 }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "options": { "sortBy": [] }
    },
    {
      "id": 5,
      "title": "Active Connections",
      "type": "bargauge",
      "gridPos": { "x": 8, "y": 10, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "suitecrm_mcp_active_connections",
          "legendFormat": "{{entity}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 80 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showUnfilled": true
      }
    },
    {
      "id": 6,
      "title": "Profiles Configured",
      "type": "table",
      "gridPos": { "x": 16, "y": 10, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "suitecrm_mcp_profiles_configured",
          "legendFormat": "{{entity}}",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "suitecrm_mcp_gateway_sessions_active",
          "legendFormat": "{{entity}}",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true },
            "renameByName": {
              "entity": "Entity",
              "Value #A": "Profiles",
              "Value #B": "Active Sessions"
            },
            "indexByName": { "Entity": 0, "Profiles": 1, "Active Sessions": 2 }
          }
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "sortBy": [] }
    },
    {
      "id": 7,
      "title": "Errors",
      "type": "row",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 8,
      "title": "Error Rate by Entity %",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 19, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum by (entity) (rate(suitecrm_mcp_tool_calls_total{status=\"error\"}[5m])) / sum by (entity) (rate(suitecrm_mcp_tool_calls_total[5m])) * 100",
          "legendFormat": "{{entity}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 9,
      "title": "Auth Failures / min",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 19, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum by (entity) (rate(suitecrm_mcp_auth_failures_total[5m]) * 60)",
          "legendFormat": "{{entity}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 10,
      "title": "Logs",
      "type": "row",
      "gridPos": { "x": 0, "y": 27, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 11,
      "title": "Live Logs (all entities)",
      "type": "logs",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "Loki" },
          "expr": "{service=~\"suitecrm.*\"}",
          "legendFormat": ""
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "id": 12,
      "title": "Auth",
      "type": "row",
      "gridPos": { "x": 0, "y": 38, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 13,
      "title": "Auth Service Health",
      "type": "stat",
      "gridPos": { "x": 0, "y": 39, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "up{job=\"suitecrm-mcp-auth\"}",
          "legendFormat": "auth"
        }
      ],
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 14,
      "title": "Logins Today",
      "type": "stat",
      "gridPos": { "x": 4, "y": 39, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum(increase(suitecrm_auth_logins_total[24h]))",
          "legendFormat": "logins"
        }
      ],
      "options": {
        "colorMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 15,
      "title": "Active Gateway Sessions",
      "type": "stat",
      "gridPos": { "x": 8, "y": 39, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "suitecrm_auth_sessions_active",
          "legendFormat": "sessions"
        }
      ],
      "options": {
        "colorMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      }
    }
  ]
}
