{
  "title": "SuiteCRM MCP Gateway",
  "uid": "suitecrm-mcp",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "entity",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(suitecrm_mcp_active_connections, entity)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Active Connections",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(suitecrm_mcp_active_connections{entity=~\"$entity\"})",
          "legendFormat": "Total"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 15 },
              { "color": "red", "value": 25 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Active Connections by Entity",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 18, "h": 4 },
      "targets": [
        {
          "expr": "suitecrm_mcp_active_connections",
          "legendFormat": "{{entity}}"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal"
      }
    },
    {
      "id": 3,
      "title": "Tool Calls / min",
      "type": "stat",
      "gridPos": { "x": 0, "y": 4, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(rate(suitecrm_mcp_tool_calls_total{entity=~\"$entity\"}[1m])) * 60",
          "legendFormat": "calls/min"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 4,
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "x": 6, "y": 4, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(rate(suitecrm_mcp_tool_calls_total{entity=~\"$entity\", status=\"error\"}[5m])) / sum(rate(suitecrm_mcp_tool_calls_total{entity=~\"$entity\"}[5m])) * 100",
          "legendFormat": "error %"
        }
      ],
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "unit": "percent"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Auth Failures",
      "type": "stat",
      "gridPos": { "x": 12, "y": 4, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(increase(suitecrm_mcp_auth_failures_total{entity=~\"$entity\"}[1h]))",
          "legendFormat": "last 1h"
        }
      ],
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Session Renewals",
      "type": "stat",
      "gridPos": { "x": 18, "y": 4, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(increase(suitecrm_mcp_session_renewals_total{entity=~\"$entity\"}[1h]))",
          "legendFormat": "last 1h"
        }
      ],
      "options": {
        "colorMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 7,
      "title": "Tool Calls Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (entity) (rate(suitecrm_mcp_tool_calls_total{entity=~\"$entity\", status=\"success\"}[2m])) * 60",
          "legendFormat": "{{entity}} success"
        },
        {
          "expr": "sum by (entity) (rate(suitecrm_mcp_tool_calls_total{entity=~\"$entity\", status=\"error\"}[2m])) * 60",
          "legendFormat": "{{entity}} error"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqpm" }
      }
    },
    {
      "id": 8,
      "title": "Tool Call Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, entity) (rate(suitecrm_mcp_tool_duration_seconds_bucket{entity=~\"$entity\"}[5m])))",
          "legendFormat": "p50 {{entity}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, entity) (rate(suitecrm_mcp_tool_duration_seconds_bucket{entity=~\"$entity\"}[5m])))",
          "legendFormat": "p95 {{entity}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, entity) (rate(suitecrm_mcp_tool_duration_seconds_bucket{entity=~\"$entity\"}[5m])))",
          "legendFormat": "p99 {{entity}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 9,
      "title": "CRM API Latency by Method (p95)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, method) (rate(suitecrm_mcp_crm_api_duration_seconds_bucket{entity=~\"$entity\"}[5m])))",
          "legendFormat": "p95 {{method}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 10,
      "title": "Top Tools by Call Count",
      "type": "barchart",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "topk(10, sum by (tool) (increase(suitecrm_mcp_tool_calls_total{entity=~\"$entity\"}[1h])))",
          "legendFormat": "{{tool}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 11,
      "title": "Active Connections History",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "suitecrm_mcp_active_connections{entity=~\"$entity\"}",
          "legendFormat": "{{entity}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 }
      }
    }
  ]
}
